      "photonic_splat": "🎨💥🌊 - Gaussian rendered via light",
      "optical_voxel": "🧊🧱🔆 - Volumetric encoded in wavelength",
      "photonic_sdf": "📏📉🌊 - Distance field via phase",
      "optical_material": "💎⚙️🌈 - BRDF as wavelength response",
      "holographic_lighting": "💡🌟💎 - Global illumination via interference",
