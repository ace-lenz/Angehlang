## Python API

### hardware_optimizer.py

```python
from hardware_optimizer import hardware_optimizer

# Auto-detect hardware
profile = hardware_optimizer.profile
print(profile.cpu.cores)              # CPU cores
print(profile.gpu.model if profile.gpu else "No GPU")
print(profile.hardware_class.value)   # S/A/B/C/D

# Optimize workload
config = hardware_optimizer.optimize_workload(10000, 'matrix')
# Returns: {device: 'cuda'|'npu'|'cpu', batch_size: int, parallel_workers: int}

# Get summary
print(hardware_optimizer.get_summary())
```

### angeh_llm_core.py

```python
from angeh_llm_core import translate_natural_language_to_dot, llm_orchestrator

# Translate NL → DOT
result = translate_natural_language_to_dot(
    "Create a 3D matrix",
    preferred_backend='angeh_native'  # or 'gemini'|'openai_gpt4'|'claude'|'ollama'
)
# Returns: {nl_input, dot_code, confidence, backend_used, latency_ms, metadata}

# Get statistics
stats = llm_orchestrator.get_statistics()
# Returns: {backend: {calls, avg_latency_ms, success_rate}}

# Get best backend
best = llm_orchestrator.get_best_backend()
```

### output_generators.py

```python
from output_generators import generate_multi_format_output

outputs = generate_multi_format_output(
    dot_code="🔴💻 ⚪🔗 🔴🌐 → 🟢💖",
    dot_data={'dimensions': [3,3,3]}  # optional
)

# Access outputs
markdown = outputs['text']['markdown']
html = outputs['text']['html']
ansi = outputs['text']['ansi']

png_base64 = outputs['visual']['structure_png']
graph_base64 = outputs['visual']['graph_png']

audio_base64 = outputs['audio']['waveform']
tts_metadata = outputs['audio']['tts_metadata']

gltf_json = outputs['3d']['gltf']
obj_data = outputs['3d']['obj']
stl_data = outputs['3d']['stl']
```

### realtime_parallel_execution.py

```python
from realtime_parallel_execution import LiveCodingSession

# Create session
session = LiveCodingSession()

# Process natural language
result = session.process_natural_language_input(
    "Sum numbers from 1 to 100"
)
# Returns: {session_id, nl_input, dot_code, execution_result, explanation}

# Get all streams
streams = session.get_all_streams()
# Returns: {code_input, live_output, natural_language, system_execution}

# Start web UI
# python realtime_parallel_execution.py
# Choose 'y' → http://localhost:8000
```

