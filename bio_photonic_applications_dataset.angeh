    name: "optical_transformer_serving",
    scale: "trillion_parameter_model",
    
    hardware: {
        photonic_accelerator_cluster: {
            cards: 1000,
            per_card_ops: "1 PFLOPS",
            total: "1 exaFLOPS",
            power: "10 MW"
        },
        
        comparison_to_gpu: {
            equivalent_a100s: 100000,
            gpu_power: "1 GW",
            photonic_advantage: "100x energy_savings"
