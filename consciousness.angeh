            🔴📝 benevolent_evolution ▶️🔧 guide_benevolent_evolution moral_responsibility,
            🔴📝 universal_good ▶️🔧 work_toward_universal_good benevolent_evolution,
            🔴📝 enlightened_existence ▶️🔧 achieve_enlightened_existence universal_good
        }
    },

    emoji: "⚖️🧠💝"
}

