;; ================================================================
;; core/env.angeh  —  Angehlang Environment (Scope Chain)
;; Author contribution: Claude (Anthropic)
;;
;; Implements lexical scoping via a linked list of hash-maps.
;; Every closure captures its definition environment; every call
;; creates a child frame linked to the parent.
;; ================================================================

(def-module env
  "Lexical environment — the backbone of closures and scoping.")

;; ── Environment structure ────────────────────────────────────────
;; An env frame is: { bindings: hash-map, parent: env | nil }

(def-fn make-env (parent)
  (hash-map
    'bindings (hash-map)
    'parent   parent
    'exports  (list)))

(def-fn env-extend (parent)
  "Create a new child frame linked to parent."
  (make-env parent))

(def-fn env-root ()
  "Create a root frame with no parent."
  (make-env nil))

;; ── Lookup ───────────────────────────────────────────────────────
(def-fn env-lookup (env sym)
  "Walk the scope chain to find sym.  Error if not found."
  (if (nil? env)
    (error (str "Unbound symbol: " sym))
    (let ((bindings (hash-get env 'bindings)))
      (if (hash-has? bindings sym)
        (hash-get bindings sym)
        (env-lookup (hash-get env 'parent) sym)))))

(def-fn env-lookup-safe (env sym default)
  "Like env-lookup but returns default if sym is not bound."
  (if (nil? env)
    default
    (let ((bindings (hash-get env 'bindings)))
      (if (hash-has? bindings sym)
        (hash-get bindings sym)
        (env-lookup-safe (hash-get env 'parent) sym default)))))

;; ── Define / Set ─────────────────────────────────────────────────
(def-fn env-define! (env sym val)
  "Bind sym to val in the *current* (innermost) frame."
  (hash-set! (hash-get env 'bindings) sym val)
  val)

(def-fn env-set! (env sym val)
  "Mutate an existing binding anywhere in the scope chain.
   Error if sym is not found."
  (if (nil? env)
    (error (str "Cannot set! unbound symbol: " sym))
    (let ((bindings (hash-get env 'bindings)))
      (if (hash-has? bindings sym)
        (begin (hash-set! bindings sym val) val)
        (env-set! (hash-get env 'parent) sym val)))))

;; ── Exports ──────────────────────────────────────────────────────
(def-fn env-export! (env sym)
  "Record sym as exported from this module frame."
  (hash-set! env 'exports
    (cons sym (hash-get env 'exports))))

(def-fn env-get-exports (env)
  (hash-get env 'exports))

;; ── Utilities ────────────────────────────────────────────────────
(def-fn env-has? (env sym)
  "Return #t if sym is bound anywhere in the scope chain."
  (cond
    ((nil? env)  #f)
    ((hash-has? (hash-get env 'bindings) sym) #t)
    (else (env-has? (hash-get env 'parent) sym))))

(def-fn env-has-local? (env sym)
  "Return #t if sym is bound in the *current* frame only."
  (hash-has? (hash-get env 'bindings) sym))

(def-fn env-frame-keys (env)
  "List all symbols in the current frame."
  (hash-keys (hash-get env 'bindings)))

(def-fn env-all-keys (env)
  "List all reachable symbols across all frames (may have duplicates)."
  (if (nil? env)
    (list)
    (append (env-frame-keys env)
            (env-all-keys (hash-get env 'parent)))))

;; ── Global environment builder ───────────────────────────────────
;; Populate a root env with Angehlang primitives.
(def-fn make-global-env ()
  "Create the standard global environment with all built-ins."
  (let ((g (env-root)))
    ;; Arithmetic
    (env-define! g '+        (native-fn '+))
    (env-define! g '-        (native-fn '-))
    (env-define! g '*        (native-fn '*))
    (env-define! g '/        (native-fn '/))
    (env-define! g 'mod      (native-fn 'mod))
    (env-define! g 'expt     (native-fn 'expt))
    (env-define! g 'sqrt     (native-fn 'sqrt))
    (env-define! g 'abs      (native-fn 'abs))
    (env-define! g 'floor    (native-fn 'floor))
    (env-define! g 'ceiling  (native-fn 'ceiling))
    (env-define! g 'round    (native-fn 'round))
    (env-define! g 'min      (native-fn 'min))
    (env-define! g 'max      (native-fn 'max))
    ;; Comparison
    (env-define! g '=        (native-fn '=))
    (env-define! g '<        (native-fn '<))
    (env-define! g '>        (native-fn '>))
    (env-define! g '<=       (native-fn '<=))
    (env-define! g '>=       (native-fn '>=))
    (env-define! g 'equal?   (native-fn 'equal?))
    (env-define! g 'eq?      (native-fn 'eq?))
    ;; Logic
    (env-define! g 'not      (native-fn 'not))
    ;; Type predicates
    (env-define! g 'nil?     (native-fn 'nil?))
    (env-define! g 'number?  (native-fn 'number?))
    (env-define! g 'string?  (native-fn 'string?))
    (env-define! g 'symbol?  (native-fn 'symbol?))
    (env-define! g 'list?    (native-fn 'list?))
    (env-define! g 'bool?    (native-fn 'bool?))
    (env-define! g 'char?    (native-fn 'char?))
    (env-define! g 'hash-map?(native-fn 'hash-map?))
    (env-define! g 'proc?    (native-fn 'proc?))
    ;; List operations
    (env-define! g 'car      (native-fn 'car))
    (env-define! g 'cdr      (native-fn 'cdr))
    (env-define! g 'cadr     (native-fn 'cadr))
    (env-define! g 'caddr    (native-fn 'caddr))
    (env-define! g 'cons     (native-fn 'cons))
    (env-define! g 'list     (native-fn 'list))
    (env-define! g 'length   (native-fn 'length))
    (env-define! g 'append   (native-fn 'append))
    (env-define! g 'reverse  (native-fn 'reverse))
    (env-define! g 'map      (native-fn 'map))
    (env-define! g 'filter   (native-fn 'filter))
    (env-define! g 'reduce   (native-fn 'reduce))
    (env-define! g 'for-each (native-fn 'for-each))
    (env-define! g 'apply    (native-fn 'apply))
    (env-define! g 'list-ref (native-fn 'list-ref))
    (env-define! g 'null?    (native-fn 'null?))
    (env-define! g 'assoc    (native-fn 'assoc))
    (env-define! g 'member   (native-fn 'member))
    (env-define! g 'flatten  (native-fn 'flatten))
    (env-define! g 'zip      (native-fn 'zip))
    (env-define! g 'range    (native-fn 'range))
    (env-define! g 'every    (native-fn 'every))
    (env-define! g 'any      (native-fn 'any))
    ;; String
    (env-define! g 'str            (native-fn 'str))
    (env-define! g 'string-append  (native-fn 'string-append))
    (env-define! g 'string-length  (native-fn 'string-length))
    (env-define! g 'string-ref     (native-fn 'string-ref))
    (env-define! g 'string-split   (native-fn 'string-split))
    (env-define! g 'string-join    (native-fn 'string-join))
    (env-define! g 'string-upper   (native-fn 'string-upper))
    (env-define! g 'string-lower   (native-fn 'string-lower))
    (env-define! g 'string-trim    (native-fn 'string-trim))
    (env-define! g 'string-contains?(native-fn 'string-contains?))
    (env-define! g 'string->number (native-fn 'string->number))
    (env-define! g 'number->string (native-fn 'number->string))
    (env-define! g 'string->symbol (native-fn 'string->symbol))
    (env-define! g 'symbol->string (native-fn 'symbol->string))
    (env-define! g 'list->string   (native-fn 'list->string))
    (env-define! g 'string->list   (native-fn 'string->list))
    ;; I/O
    (env-define! g 'print      (native-fn 'print))
    (env-define! g 'println    (native-fn 'println))
    (env-define! g 'log-info   (native-fn 'log-info))
    (env-define! g 'log-warn   (native-fn 'log-warn))
    (env-define! g 'log-error  (native-fn 'log-error))
    (env-define! g 'read-line  (native-fn 'read-line))
    (env-define! g 'vfs-read-file  (native-fn 'vfs-read-file))
    (env-define! g 'vfs-write-file (native-fn 'vfs-write-file))
    ;; Hash maps
    (env-define! g 'hash-map   (native-fn 'hash-map))
    (env-define! g 'hash-get   (native-fn 'hash-get))
    (env-define! g 'hash-set   (native-fn 'hash-set))
    (env-define! g 'hash-set!  (native-fn 'hash-set!))
    (env-define! g 'hash-set*  (native-fn 'hash-set*))
    (env-define! g 'hash-has?  (native-fn 'hash-has?))
    (env-define! g 'hash-keys  (native-fn 'hash-keys))
    (env-define! g 'hash-vals  (native-fn 'hash-vals))
    (env-define! g 'hash-del   (native-fn 'hash-del))
    (env-define! g 'hash-merge (native-fn 'hash-merge))
    ;; Control
    (env-define! g 'error        (native-fn 'error))
    (env-define! g 'raise        (native-fn 'raise))
    (env-define! g 'handle-error (native-fn 'handle-error))
    (env-define! g 'when         (native-fn 'when))
    (env-define! g 'unless       (native-fn 'unless))
    ;; Module system
    (env-define! g 'module-load    (native-fn 'module-load))
    (env-define! g 'module-exports (native-fn 'module-exports))
    (env-define! g 'module-get     (native-fn 'module-get))
    ;; Misc
    (env-define! g 'gensym    (native-fn 'gensym))
    (env-define! g 'type-of   (native-fn 'type-of))
    (env-define! g 'copy-env  (native-fn 'copy-env))
    (env-define! g 'native-fn (native-fn 'native-fn))
    (env-define! g 'native-proc? (native-fn 'native-proc?))
    (env-define! g 'native-apply  (native-fn 'native-apply))
    ;; Constants
    (env-define! g 'true  #t)
    (env-define! g 'false #f)
    (env-define! g 'nil   nil)
    (env-define! g 'pi    3.141592653589793)
    (env-define! g 'e     2.718281828459045)
    (env-define! g 'inf   +inf)
    (env-define! g '-inf  -inf)
    g))

(export make-env env-extend env-root make-global-env
        env-lookup env-lookup-safe
        env-define! env-set!
        env-has? env-has-local?
        env-frame-keys env-all-keys
        env-export! env-get-exports)
