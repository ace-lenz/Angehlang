;; ================================================================
;; tests/framework.angeh  —  Angehlang Test Framework
;; Author contribution: Claude (Anthropic)
;;
;; A complete xUnit-style test framework:
;;   • assert-equal, assert-not, assert-throws, assert-type
;;   • Test suites and groups
;;   • Before/after hooks
;;   • Parameterized tests
;;   • Property-based testing (QuickCheck style)
;;   • Coverage tracking
;;   • TAP-compatible output
;;   • Colorized terminal output
;; ================================================================

(def-module test-framework
  "Native test framework — test Angehlang with Angehlang.")

;; ── State ────────────────────────────────────────────────────────
(def __suites__    (list))
(def __current__   nil)
(def __results__   (list))
(def __pass-count__ 0)
(def __fail-count__ 0)
(def __skip-count__ 0)

;; ── Terminal colors ──────────────────────────────────────────────
(def CLR-GREEN  "\x1b[32m")
(def CLR-RED    "\x1b[31m")
(def CLR-YELLOW "\x1b[33m")
(def CLR-CYAN   "\x1b[36m")
(def CLR-RESET  "\x1b[0m")
(def CLR-BOLD   "\x1b[1m")

(def-fn colored (color s)
  (str color s CLR-RESET))

;; ── Result types ─────────────────────────────────────────────────
(def-fn make-pass (name)
  (hash-map 'status 'pass 'name name 'message nil))

(def-fn make-fail (name message expected actual)
  (hash-map 'status 'fail 'name name
            'message message 'expected expected 'actual actual))

(def-fn make-skip (name reason)
  (hash-map 'status 'skip 'name name 'message reason))

(def-fn make-error (name err)
  (hash-map 'status 'error 'name name 'message (str err)))

;; ── Assertion primitives ─────────────────────────────────────────
(def-fn assert-equal (actual expected)
  (when (not (equal? actual expected))
    (error (hash-map
             'type     'assertion-failure
             'expected expected
             'actual   actual
             'message  (str "Expected: " expected "\n  Actual: " actual)))))

(def-fn assert-not-equal (actual expected)
  (when (equal? actual expected)
    (error (hash-map
             'type    'assertion-failure
             'message (str "Expected values to differ, both were: " actual)))))

(def-fn assert-true (v)
  (when (not v)
    (error (hash-map 'type 'assertion-failure
                     'message (str "Expected truthy, got: " v)))))

(def-fn assert-false (v)
  (when v
    (error (hash-map 'type 'assertion-failure
                     'message (str "Expected falsy, got: " v)))))

(def-fn assert-nil (v)
  (when (not (nil? v))
    (error (hash-map 'type 'assertion-failure
                     'message (str "Expected nil, got: " v)))))

(def-fn assert-not-nil (v)
  (when (nil? v)
    (error (hash-map 'type 'assertion-failure
                     'message "Expected non-nil value"))))

(def-fn assert-type (v expected-type)
  (let ((actual-type (type-of v)))
    (when (not (equal? actual-type expected-type))
      (error (hash-map 'type     'assertion-failure
                       'message  (str "Expected type " expected-type
                                      ", got " actual-type))))))

(def-fn assert-throws (thunk)
  "Assert that thunk raises an error."
  (let ((threw #f))
    (handle-error
      (lambda () (thunk) (set! threw #f))
      (lambda (_) (set! threw #t)))
    (when (not threw)
      (error (hash-map 'type 'assertion-failure
                       'message "Expected an exception to be thrown")))))

(def-fn assert-throws-matching (thunk pred)
  "Assert thunk throws and error matches predicate."
  (let ((threw nil))
    (handle-error
      (lambda () (thunk))
      (lambda (e) (set! threw e)))
    (when (nil? threw)
      (error (hash-map 'type 'assertion-failure
                       'message "Expected an exception to be thrown")))
    (when (not (pred threw))
      (error (hash-map 'type 'assertion-failure
                       'message (str "Exception did not match predicate: " threw))))))

(def-fn assert-approx (actual expected epsilon)
  "Assert |actual - expected| < epsilon."
  (when (>= (abs (- actual expected)) epsilon)
    (error (hash-map 'type    'assertion-failure
                     'message (str "Expected ~" expected
                                   " ± " epsilon ", got " actual)))))

(def-fn assert-contains (collection item)
  "Assert item is in collection (list or string)."
  (cond
    ((list? collection)
     (when (not (member item collection))
       (error (hash-map 'type 'assertion-failure
                        'message (str "Expected " item " in " collection)))))
    ((string? collection)
     (when (not (string-contains? collection (str item)))
       (error (hash-map 'type 'assertion-failure
                        'message (str "Expected '" item "' in \"" collection "\"")))))
    (else
     (error "assert-contains: not a list or string"))))

(def-fn assert-length (collection n)
  (let ((actual (length collection)))
    (when (not (= actual n))
      (error (hash-map 'type    'assertion-failure
                       'message (str "Expected length " n ", got " actual))))))

;; ── Test definition ──────────────────────────────────────────────
(def-fn run-test (name thunk hooks)
  "Execute a single test.  Returns a result record."
  ;; before
  (when (hash-has? hooks 'before)
    (handle-error (lambda () ((hash-get hooks 'before))) (lambda (_) nil)))
  ;; run
  (let ((result
         (handle-error
           (lambda ()
             (thunk)
             (make-pass name))
           (lambda (e)
             (if (and (hash-map? e)
                      (equal? (hash-get e 'type) 'assertion-failure))
               (make-fail name
                          (hash-get e 'message)
                          (hash-get e 'expected)
                          (hash-get e 'actual))
               (make-error name e))))))
  ;; after
  (when (hash-has? hooks 'after)
    (handle-error (lambda () ((hash-get hooks 'after))) (lambda (_) nil)))
  result))

;; ── Suite definition ─────────────────────────────────────────────
(def-fn make-suite (name tests before-all after-all before-each after-each)
  (hash-map
    'name        name
    'tests       tests
    'before-all  before-all
    'after-all   after-all
    'before-each before-each
    'after-each  after-each))

(def-macro describe (name body)
  "Define a test suite."
  `(let ((__suite-tests__ (list))
         (__before-each__ nil)
         (__after-each__  nil)
         (__before-all__  nil)
         (__after-all__   nil))
     ,body
     (set! __suites__
       (cons (make-suite ,name __suite-tests__
                         __before-all__ __after-all__
                         __before-each__ __after-each__)
             __suites__))))

(def-macro it (name body)
  "Define a test case inside describe."
  `(set! __suite-tests__
     (cons (list ,name (lambda () ,body)) __suite-tests__)))

(def-macro before-each (body)
  `(set! __before-each__ (lambda () ,body)))

(def-macro after-each (body)
  `(set! __after-each__ (lambda () ,body)))

(def-macro before-all (body)
  `(set! __before-all__ (lambda () ,body)))

(def-macro after-all (body)
  `(set! __after-all__ (lambda () ,body)))

(def-macro skip (name reason)
  "Mark a test as skipped."
  `(set! __suite-tests__
     (cons (list ,name (lambda () (raise (hash-map 'type 'skip 'reason ,reason))))
           __suite-tests__)))

;; ── Parameterized tests ──────────────────────────────────────────
(def-macro test-each (name cases body-fn)
  "Run body-fn for each case in cases."
  `(for-each ,cases
     (lambda (c)
       (set! __suite-tests__
         (cons (list (str ,name " [" c "]")
                     (lambda () (,body-fn c)))
               __suite-tests__)))))

;; ── Property-based testing ───────────────────────────────────────
(def-fn gen-int (min max)
  "Generate a random integer in [min, max]."
  (+ min (floor (* (native-random) (+ 1 (- max min))))))

(def-fn gen-float ()
  (* (native-random) 1000.0))

(def-fn gen-string (max-len)
  (let ((len (gen-int 0 max-len)))
    (list->string
      (map (lambda (_)
             (string-ref "abcdefghijklmnopqrstuvwxyz" (gen-int 0 25)))
           (range 0 len)))))

(def-fn gen-list (gen-elem max-len)
  (map (lambda (_) (gen-elem)) (range 0 (gen-int 0 max-len))))

(def-fn property (name generator predicate trials)
  "Run predicate on 'trials' randomly-generated inputs."
  (let loop ((n trials) (shrink nil))
    (if (= n 0)
      (make-pass name)
      (let ((input (generator)))
        (handle-error
          (lambda ()
            (predicate input)
            (loop (- n 1) nil))
          (lambda (e)
            (make-fail name
              (str "Property failed on input: " input "\n  " e)
              "property holds"
              input)))))))

(def-macro for-all (name gen pred n)
  `(set! __suite-tests__
     (cons (list ,name (lambda () (property ,name ,gen ,pred ,n)))
           __suite-tests__)))

;; ── Runner ───────────────────────────────────────────────────────
(def-fn run-suite (suite)
  (let ((name       (hash-get suite 'name))
        (tests      (reverse (hash-get suite 'tests)))
        (before-all (hash-get suite 'before-all))
        (after-all  (hash-get suite 'after-all))
        (b-each     (hash-get suite 'before-each))
        (a-each     (hash-get suite 'after-each)))
    (print (str "\n" (colored CLR-BOLD (str "  📋 " name))))
    (when before-all (before-all))
    (for-each tests
      (lambda (t)
        (let* ((test-name (car t))
               (test-fn   (cadr t))
               (hooks     (hash-map 'before b-each 'after a-each))
               (result    (run-test test-name test-fn hooks)))
          (record-result! result)
          (print-result result))))
    (when after-all (after-all))))

(def-fn record-result! (r)
  (set! __results__ (cons r __results__))
  (cond
    ((equal? (hash-get r 'status) 'pass)
     (set! __pass-count__ (+ __pass-count__ 1)))
    ((equal? (hash-get r 'status) 'skip)
     (set! __skip-count__ (+ __skip-count__ 1)))
    (else
     (set! __fail-count__ (+ __fail-count__ 1)))))

(def-fn print-result (r)
  (let ((status (hash-get r 'status))
        (name   (hash-get r 'name)))
    (cond
      ((equal? status 'pass)
       (print (colored CLR-GREEN (str "    ✓ " name))))
      ((equal? status 'skip)
       (print (colored CLR-YELLOW (str "    ⊘ " name " [skipped: " (hash-get r 'message) "]"))))
      ((equal? status 'fail)
       (print (colored CLR-RED (str "    ✗ " name)))
       (print (colored CLR-RED (str "      " (hash-get r 'message)))))
      ((equal? status 'error)
       (print (colored CLR-RED (str "    💥 " name " [error: " (hash-get r 'message) "]")))))))

(def-fn run-all-suites ()
  "Run all registered suites and print summary."
  (print (str "\n" (colored CLR-BOLD "🧪 Angehlang Test Runner") "\n"))
  (for-each (reverse __suites__) run-suite)
  (print-summary))

(def-fn print-summary ()
  (let ((total (+ __pass-count__ __fail-count__ __skip-count__)))
    (print (str "\n" (string-repeat "─" 50)))
    (print (str "  Total:   " total))
    (print (colored CLR-GREEN  (str "  Passed:  " __pass-count__)))
    (print (colored CLR-RED    (str "  Failed:  " __fail-count__)))
    (print (colored CLR-YELLOW (str "  Skipped: " __skip-count__)))
    (print (string-repeat "─" 50))
    (if (= __fail-count__ 0)
      (print (colored CLR-GREEN "\n  ✅ All tests passed!\n"))
      (print (colored CLR-RED   "\n  ❌ Some tests failed.\n")))
    (= __fail-count__ 0)))

;; ── TAP output ───────────────────────────────────────────────────
(def-fn print-tap ()
  "Print TAP (Test Anything Protocol) output."
  (print (str "1.." (length __results__)))
  (for-each (range 1 (+ 1 (length __results__)))
    (lambda (i)
      (let ((r (list-ref (reverse __results__) (- i 1))))
        (if (equal? (hash-get r 'status) 'pass)
          (print (str "ok " i " - " (hash-get r 'name)))
          (print (str "not ok " i " - " (hash-get r 'name)
                      "\n  # " (hash-get r 'message))))))))

;; ── Built-in sanity tests ─────────────────────────────────────────
(describe "Core sanity"
  (it "arithmetic" (assert-equal (+ 2 3) 5))
  (it "strings"    (assert-equal (str "hello" " " "world") "hello world"))
  (it "lists"      (assert-equal (map (lambda (x) (* x x)) (list 1 2 3))
                                 (list 1 4 9)))
  (it "closures"   (let ((make-adder (lambda (n) (lambda (x) (+ x n)))))
                     (assert-equal ((make-adder 10) 5) 15)))
  (it "tail calls" (def-fn count-down (n acc)
                     (if (= n 0) acc (count-down (- n 1) (+ acc 1))))
                   (assert-equal (count-down 100000 0) 100000)))

(export
  ;; Assertions
  assert-equal assert-not-equal assert-true assert-false
  assert-nil assert-not-nil assert-type assert-throws
  assert-throws-matching assert-approx assert-contains assert-length
  ;; Macros
  describe it before-each after-each before-all after-all skip
  test-each for-all
  ;; Generators
  gen-int gen-float gen-string gen-list property
  ;; Runner
  run-all-suites print-tap print-summary)
