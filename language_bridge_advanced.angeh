    "julia"      (struct (family "scientific") (tier 1) (runtime "julia") (ext ".jl"))
    "typescript" (struct (family "scripting") (tier 1) (compiler "tsc") (runtime "node") (ext ".ts"))
    "dart"       (struct (family "vm") (tier 1) (runtime "dart") (ext ".dart"))
    
    ;; ─── TIER 2: COMPILED LANGUAGES (10) ───
