    "q"          (struct (family "array") (tier 6) (runtime "q") (ext ".q"))solidity"   (struct (family "blockchain") (tier 6) (compiler "solc") (ext ".sol"))
    "vyper"      (struct (family "blockchain") (tier 6) (compiler "vyper") (ext ".vy"))
    "move"       (struct (family "blockchain") (tier 6) (compiler "move") (ext ".move"))
