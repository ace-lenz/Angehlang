(def-module math)

(def sin math.sin)
(def cos math.cos)
(def tan math.tan)
(def asin math.asin)
(def acos math.acos)
(def atan math.atan)
(def sqrt math.sqrt)
(def log math.log)
(def exp math.exp)
(def pi math.pi)
(def e math.e)
(def pow math.pow)
(def floor math.floor)
(def ceil math.ceil)
(def abs math.abs)

(export
  sin cos tan asin acos atan
  sqrt log exp pi e pow
  floor ceil abs)
