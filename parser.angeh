;; ================================================================
;; core/parser.angeh  —  Angehlang Self-Hosted Recursive-Descent Parser
;; Author contribution: Claude (Anthropic)
;; Parses a flat token stream (from lexer.angeh) into an AST of
;; nested S-expressions. No Python. No C. Pure .angeh.
;; ================================================================

(def-module parser
  "Native S-expression parser. Converts token lists to AST nodes.")

(import lexer)

;; ── Parser state ─────────────────────────────────────────────────
(def-fn make-parser (tokens)
  (hash-map 'tokens tokens 'pos 0))

(def-fn ps-peek (ps)
  (list-ref (hash-get ps 'tokens) (hash-get ps 'pos)))

(def-fn ps-advance (ps)
  (hash-set ps 'pos (+ (hash-get ps 'pos) 1)))

(def-fn ps-end? (ps)
  (equal? (hash-get (ps-peek ps) 'type) TOKEN-EOF))

(def-fn ps-expect (ps type)
  (let ((tok (ps-peek ps)))
    (if (equal? (hash-get tok 'type) type)
      (list (ps-advance ps) (hash-get tok 'value))
      (error (str "Parser: expected " type
                  " but got " (hash-get tok 'type)
                  " at " (hash-get tok 'line) ":" (hash-get tok 'col))))))

;; ── Parse one expression ─────────────────────────────────────────
(def-fn parse-expr (ps)
  (let ((tok (ps-peek ps)))
    (let ((type  (hash-get tok 'type))
          (value (hash-get tok 'value)))
      (cond
        ;; Atom types
        ((equal? type TOKEN-NUMBER) (list (ps-advance ps) value))
        ((equal? type TOKEN-STRING) (list (ps-advance ps) value))
        ((equal? type TOKEN-BOOL)   (list (ps-advance ps) value))
        ((equal? type TOKEN-NIL)    (list (ps-advance ps) nil))
        ((equal? type TOKEN-SYMBOL) (list (ps-advance ps) value))
        ;; List  ( expr* )
        ((equal? type TOKEN-LPAREN)
         (parse-list (ps-advance ps) (list)))
        ;; EOF — return nil
        ((equal? type TOKEN-EOF)
         (list ps nil))
        (else
         (error (str "Parser: unexpected token type " type)))))))

;; ── Parse list body until RPAREN ────────────────────────────────
(def-fn parse-list (ps acc)
  (let ((tok (ps-peek ps)))
    (cond
      ((equal? (hash-get tok 'type) TOKEN-EOF)
       (error (str "Parser: unmatched '(' — reached EOF")))
      ((equal? (hash-get tok 'type) TOKEN-RPAREN)
       ;; consume ')' and return accumulated list
       (list (ps-advance ps) (reverse acc)))
      (else
       (let* ((result (parse-expr ps))
              (ps2    (car result))
              (node   (cadr result)))
         (parse-list ps2 (cons node acc)))))))

;; ── Parse all top-level forms ────────────────────────────────────
(def-fn parse-all (ps acc)
  (if (ps-end? ps)
    (reverse acc)
    (let* ((result (parse-expr ps))
           (ps2    (car result))
           (node   (cadr result)))
      (parse-all ps2 (if (nil? node) acc (cons node acc))))))

;; ── Public API ───────────────────────────────────────────────────
(def-fn parse (tokens)
  "Parse a token list into a list of AST nodes (S-expressions)."
  (parse-all (make-parser tokens) (list)))

(def-fn parse-source (source)
  "Tokenize and parse a source string in one step."
  (parse (tokenize source)))

(def-fn parse-file (path)
  "Tokenize and parse a .angeh file."
  (parse (tokenize-file path)))

(export parse parse-source parse-file)
