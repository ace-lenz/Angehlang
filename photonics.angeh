                topological_charge: ℓ,
                
                states_available: "unlimited",
                multiplexing_dimension: "space"
            },
            
            applications: {
                optical_communications: "OAM_multiplexing",
                optical_tweezers: "particle_spinning",
                quantum_information: "high_dimensional_qubits"
            }
        }
    },
    
    // Temporal manipulation
    temporal_control: {
        pulse_shaping: {
            fourier_synthesis: {
                // Fourier transform -> manipulate spectrum -> inverse FT
                🌈 spectral_decompose(pulse),
                manipulate_spectrum(amplitude, phase),
                pulse_shaped: inverse_transform
            },
            
            applications: {
                chirp_compensation: "dispersion_precompensation",
                arbitrary_waveforms: "communications",
                optimal_control: "quantum_gates"
            }
        },
        
        time_lens: {
            // Temporal analog of spatial lens
            chirp_signal: "frequency_sweep",
            dispersion: "time_focusing",
            
            applications: ["time_magnification", "pulse_compression"]
        }
    },
    
    // Frequency manipulation
    frequency_control: {
        frequency_shifting: {
            single_sideband: {
                method: "acousto_optic_modulator",
                shift: "±RF_frequency",
                range: "MHz to GHz"
            },
            
            optical_comb: {
                // Generate multiple frequencies
                mode_locked_laser: true,
                spacing: "repetition_rate",
                span: "> 100 THz",
                
                applications: "precision_spectroscopy"
            }
        },
        
        frequency_conversion: {
            sum_frequency: "ω₃ = ω₁ + ω₂",
            difference_frequency: "ω₃ = ω₁ - ω₂",
            
            phase_matching: "Δk = k₃ - k₁ - k₂ = 0",
            
            techniques: {
                angle_tuning: "vary_crystal_angle",
                temperature_tuning: "vary_T",
                quasi_phase_matching: "periodic_poling"
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// PHOTONIC PROGRAMMING EXAMPLES
// ═══════════════════════════════════════════════════════════════════

dot photonic_programs @demonstrations {
    
    // Example 1: Optical Neural Network Layer
    program optical_dense_layer {
        inputs: photonic_vector[N],
        weights: MZI_mesh[N][M],
        output: photonic_vector[M],
        
        execution: {
            for i in range(M):
                // Weighted sum via optical interference
                sum = 0
                for j in range(N):
                    🔀 interfere(inputs[j], weights[j][i]),
                    sum += interference_result
                
                ⚡ amplify(sum),  // Optical gain
                output[i] = 📡 measure(sum)
        },
        
        performance: {
            matrix_multiply: "O(1) time",  // Parallel
            energy: "fJ per MAC",
            throughput: "THz"
        }
    },
    
    // Example 2: All-Optical Packet Router
    program wavelength_router {
        input: packet_stream,
        routing_table: wavelength_to_port_map,
        
        execution: {
            for packet in stream:
                λ = packet.wavelength
                        
                // Hardware wavelength routing
                switch(λ):
                    case 1550: 🌊 route_to(port_1)
                    case 1551: 🌊 route_to(port_2)
                    case 1552: 🌊 route_to(port_3)
                    default: 🌊 drop_packet
                
                // Routing at speed of light!
        },
        
        latency: "propagation_delay_only",
        throughput: "100 Tbps+"
    },
    
    // Example 3: Quantum State Preparation
    program prepare_bell_state {
        output: "|Φ⁺⟩ = (|00⟩ + |11⟩)/√2",
        
        execution: {
            // Single photon sources
            photon_A: 🔆(1550, single_photon),
            photon_B: 🔆(1550, single_photon),
            
            // 50/50 beam splitter
            🔀 interfere(photon_A, photon_B, 0.5),
            
            // Hong-Ou-Mandel effect
            temporal_overlap: coincident,
            bunching: both_photons_to_same_output,
            
            // Result: maximally entangled
            🔮 entangle(photon_A, photon_B)
        }
    }
}

