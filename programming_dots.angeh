    return a + b; → ⬅️⚪ 📝 ➕ 📝 (Back flow write plus write)
}

const result = add(3, 4); → 🔒📝 ⬅️📦 ▶️🔧 📝 📥🔗 🔢🔴 📥🔗 🔢🔴 (Lock write back container play tool write input links number action input links number action)
