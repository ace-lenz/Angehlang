dot QuantumInformation @quantum_information {
    // Fundamental concepts of quantum information theory

    entropy_measures: {
        von_neumann_entropy: {
            definition: "S(ρ)_=_-_Tr(ρ_log_ρ)",
            interpretation: "quantum_uncertainty",
            classical_limit: "shannon_entropy"
        },

        conditional_entropy: {
            definition: "S(A|B)_=_S(AB)_-_S(B)",
            quantum_case: "may_be_negative",
            applications: "quantum_cryptography"
        },

        mutual_information: {
            definition: "I(A:B)_=_S(A)_+_S(B)_-_S(AB)",
            quantum_version: "coherent_states_information",
            monogamy: "limited_sharing_quantum_information"
