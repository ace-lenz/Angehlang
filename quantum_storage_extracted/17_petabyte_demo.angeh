;; ── Helpers ──────────────────────────────────────────────────────────────────
(def-fn string-repeat (s n)
  (if (<= n 0) ""
    (str s (string-repeat s (- n 1)))))

(def-fn string-slice-safe (s from to)
  (let ((len (string-length s)))
    (list->string
      (let loop ((cs (string->list s)) (i 0) (acc (list)))
        (if (null? cs) (reverse acc)
          (loop (cdr cs) (+ i 1)
                (if (and (>= i from) (< i (min to len)))
                  (cons (car cs) acc) acc)))))))

(def-fn string-join (parts delim)
  (if (null? parts) ""
    (reduce (lambda (a b) (str a delim b)) (car parts) (cdr parts))))

(def-fn sin (x) (native-sin x))
(def-fn cos (x) (native-cos x))
