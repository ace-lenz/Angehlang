;; ================================================================
;; stdlib/string.angeh  —  Angehlang String Library
;; Author contribution: Claude (Anthropic)
;;
;; Complete string processing — no external dependencies:
;;   • Basic ops       (length, ref, slice, append, reverse)
;;   • Search          (find, contains?, starts?, ends?)
;;   • Transform       (upper, lower, trim, pad, replace)
;;   • Split / Join
;;   • Regex-lite      (glob pattern matching)
;;   • Unicode         (codepoint iterators, category check)
;;   • Formatting      (sprintf-style)
;;   • Parsing helpers (number, bool, symbol extraction)
;; ================================================================

(def-module string
  "Full-featured string library — pure Angehlang, no FFI required.")

;; ── Basic predicates ─────────────────────────────────────────────
(def-fn string-empty? (s)
  (= (string-length s) 0))

(def-fn string-blank? (s)
  "True if s is empty or contains only whitespace."
  (string-empty? (string-trim s)))

;; ── Slicing ──────────────────────────────────────────────────────
(def-fn string-slice (s from to)
  "Return substring [from, to)."
  (list->string
    (let loop ((cs (string->list s)) (i 0) (acc (list)))
      (cond
        ((null? cs) (reverse acc))
        ((and (>= i from) (< i to))
         (loop (cdr cs) (+ i 1) (cons (car cs) acc)))
        (else
         (loop (cdr cs) (+ i 1) acc))))))

(def-fn string-take (s n)
  "First n characters."
  (string-slice s 0 n))

(def-fn string-drop (s n)
  "All characters after index n."
  (string-slice s n (string-length s)))

(def-fn string-last (s n)
  "Last n characters."
  (let ((len (string-length s)))
    (string-slice s (max 0 (- len n)) len)))

;; ── Search ───────────────────────────────────────────────────────
(def-fn string-index-of (s sub)
  "Return index of first occurrence of sub in s, or -1."
  (let* ((slen (string-length s))
         (sublen (string-length sub)))
    (let loop ((i 0))
      (cond
        ((> (+ i sublen) slen) -1)
        ((equal? (string-slice s i (+ i sublen)) sub) i)
        (else (loop (+ i 1)))))))

(def-fn string-last-index-of (s sub)
  "Return index of last occurrence of sub in s, or -1."
  (let* ((slen (string-length s))
         (sublen (string-length sub)))
    (let loop ((i (- slen sublen)) (found -1))
      (if (< i 0)
        found
        (if (equal? (string-slice s i (+ i sublen)) sub)
          (loop (- i 1) i)
          (loop (- i 1) found))))))

(def-fn string-contains? (s sub)
  (>= (string-index-of s sub) 0))

(def-fn string-starts? (s prefix)
  (and (>= (string-length s) (string-length prefix))
       (equal? (string-take s (string-length prefix)) prefix)))

(def-fn string-ends? (s suffix)
  (let ((slen (string-length s)) (pflen (string-length suffix)))
    (and (>= slen pflen)
         (equal? (string-slice s (- slen pflen) slen) suffix))))

;; ── Case ─────────────────────────────────────────────────────────
(def-fn string-upper (s)
  (list->string (map char-upcase (string->list s))))

(def-fn string-lower (s)
  (list->string (map char-downcase (string->list s))))

(def-fn string-title-case (s)
  "Capitalize first letter of each word."
  (let loop ((chars (string->list s)) (new-word #t) (acc (list)))
    (if (null? chars)
      (list->string (reverse acc))
      (let ((ch (car chars)))
        (if (char=? ch #\space)
          (loop (cdr chars) #t (cons ch acc))
          (if new-word
            (loop (cdr chars) #f (cons (char-upcase ch) acc))
            (loop (cdr chars) #f (cons (char-downcase ch) acc))))))))

(def-fn string-camel->kebab (s)
  "Convert camelCase to kebab-case."
  (let loop ((cs (string->list s)) (acc (list)))
    (if (null? cs)
      (list->string (reverse acc))
      (let ((ch (car cs)))
        (if (and (char-upper? ch) (not (null? acc)))
          (loop (cdr cs) (cons (char-downcase ch) (cons #\- acc)))
          (loop (cdr cs) (cons (char-downcase ch) acc)))))))

(def-fn string-kebab->camel (s)
  "Convert kebab-case to camelCase."
  (let loop ((parts (string-split s "-")) (first #t) (acc (list)))
    (if (null? parts)
      (string-join (reverse acc) "")
      (let ((p (car parts)))
        (if first
          (loop (cdr parts) #f (cons p acc))
          (loop (cdr parts) #f
                (cons (str (string-upper (string-take p 1))
                           (string-drop p 1))
                      acc)))))))

;; ── Trim ─────────────────────────────────────────────────────────
(def-fn char-whitespace? (c)
  (or (char=? c #\space) (char=? c #\newline)
      (char=? c #\tab)   (char=? c #\return)))

(def-fn string-trim-left (s)
  (let loop ((cs (string->list s)))
    (if (or (null? cs) (not (char-whitespace? (car cs))))
      (list->string cs)
      (loop (cdr cs)))))

(def-fn string-trim-right (s)
  (list->string (reverse (string->list (string-trim-left
    (list->string (reverse (string->list s))))))))

(def-fn string-trim (s)
  (string-trim-right (string-trim-left s)))

;; ── Padding ──────────────────────────────────────────────────────
(def-fn string-pad-left (s n ch)
  "Left-pad s with ch to reach length n."
  (let ((fill (max 0 (- n (string-length s)))))
    (str (make-string fill ch) s)))

(def-fn string-pad-right (s n ch)
  "Right-pad s with ch to reach length n."
  (let ((fill (max 0 (- n (string-length s)))))
    (str s (make-string fill ch))))

(def-fn make-string (n ch)
  (list->string (map (lambda (_) ch) (range 0 n))))

;; ── Replace ──────────────────────────────────────────────────────
(def-fn string-replace (s from to)
  "Replace first occurrence of from with to."
  (let ((idx (string-index-of s from)))
    (if (= idx -1)
      s
      (str (string-take s idx)
           to
           (string-drop s (+ idx (string-length from)))))))

(def-fn string-replace-all (s from to)
  "Replace all occurrences of from with to."
  (if (string-empty? from)
    s
    (let loop ((remaining s) (acc ""))
      (let ((idx (string-index-of remaining from)))
        (if (= idx -1)
          (str acc remaining)
          (loop (string-drop remaining (+ idx (string-length from)))
                (str acc (string-take remaining idx) to)))))))

;; ── Split / Join ─────────────────────────────────────────────────
(def-fn string-split (s delim)
  "Split s by delimiter string.  Returns list of substrings."
  (if (string-empty? delim)
    (map (lambda (c) (str c)) (string->list s))
    (let loop ((remaining s) (acc (list)))
      (let ((idx (string-index-of remaining delim)))
        (if (= idx -1)
          (reverse (cons remaining acc))
          (loop (string-drop remaining (+ idx (string-length delim)))
                (cons (string-take remaining idx) acc)))))))

(def-fn string-split-lines (s)
  "Split into lines, handling \\r\\n and \\n."
  (string-split (string-replace-all s "\r\n" "\n") "\n"))

(def-fn string-join (parts delim)
  "Join a list of strings with delimiter."
  (if (null? parts)
    ""
    (reduce (lambda (acc p) (str acc delim p))
            (car parts)
            (cdr parts))))

;; ── Repeat ───────────────────────────────────────────────────────
(def-fn string-repeat (s n)
  "Repeat s n times."
  (string-join (map (lambda (_) s) (range 0 n)) ""))

;; ── Glob pattern matching ─────────────────────────────────────────
;; Supports: * (any sequence), ? (any single char), [...] (char class)

(def-fn glob-match? (pattern text)
  "Match text against a glob pattern."
  (glob-match-chars (string->list pattern) (string->list text)))

(def-fn glob-match-chars (pat txt)
  (cond
    ;; Both exhausted — match
    ((and (null? pat) (null? txt)) #t)
    ;; Pattern exhausted, text not
    ((null? pat) #f)
    ;; Wildcard *: try matching 0 or more chars
    ((char=? (car pat) #\*)
     (or (glob-match-chars (cdr pat) txt)
         (and (not (null? txt))
              (glob-match-chars pat (cdr txt)))))
    ;; Text exhausted
    ((null? txt) #f)
    ;; Single char wildcard ?
    ((char=? (car pat) #\?)
     (glob-match-chars (cdr pat) (cdr txt)))
    ;; Character class [abc] or [a-z]
    ((char=? (car pat) #\[)
     (let* ((close (index-of (cdr pat) #\]))
            (class (take (cdr pat) close))
            (rest  (drop (cdr pat) (+ close 1))))
       (and (char-in-class? (car txt) class)
            (glob-match-chars rest (cdr txt)))))
    ;; Literal match
    ((char=? (car pat) (car txt))
     (glob-match-chars (cdr pat) (cdr txt)))
    ;; Mismatch
    (else #f)))

(def-fn char-in-class? (ch class)
  (cond
    ((null? class) #f)
    ;; Range: a-z
    ((and (>= (length class) 3) (char=? (cadr class) #\-))
     (or (and (char>=? ch (car class)) (char<=? ch (caddr class)))
         (char-in-class? ch (drop class 3))))
    ;; Literal
    ((char=? ch (car class)) #t)
    (else (char-in-class? ch (cdr class)))))

(def-fn index-of (lst item)
  (let loop ((ls lst) (i 0))
    (cond ((null? ls) -1)
          ((equal? (car ls) item) i)
          (else (loop (cdr ls) (+ i 1))))))

;; ── sprintf-style formatting ─────────────────────────────────────
;; Tokens: %s string  %d int  %f float  %b bool  %% literal %

(def-fn format (template . args)
  "Format string with positional args.  Use %s %d %f %b %%."
  (let loop ((chars (string->list template)) (args args) (acc ""))
    (cond
      ((null? chars) acc)
      ((and (char=? (car chars) #\%)
            (not (null? (cdr chars))))
       (let ((spec (cadr chars))
             (rest (cddr chars)))
         (cond
           ((char=? spec #\s)
            (loop rest (cdr args) (str acc (car args))))
           ((char=? spec #\d)
            (loop rest (cdr args) (str acc (number->string (floor (car args))))))
           ((char=? spec #\f)
            (loop rest (cdr args) (str acc (format-float (car args) 6))))
           ((char=? spec #\b)
            (loop rest (cdr args) (str acc (if (car args) "true" "false"))))
           ((char=? spec #\%)
            (loop rest args (str acc "%")))
           (else
            (loop rest args (str acc "%" spec))))))
      (else
       (loop (cdr chars) args (str acc (car chars)))))))

(def-fn format-float (n precision)
  "Format a float with given decimal places."
  (let* ((factor (expt 10 precision))
         (rounded (/ (round (* n factor)) factor))
         (int-part (floor rounded))
         (frac-part (abs (- rounded int-part)))
         (frac-str (string-drop (number->string (+ 1 (round (* frac-part factor)))) 1)))
    (str (number->string int-part) "." (string-pad-right frac-str precision #\0))))

;; ── Unicode / character category helpers ─────────────────────────
(def-fn char-letter? (c)
  (or (and (char>=? c #\a) (char<=? c #\z))
      (and (char>=? c #\A) (char<=? c #\Z))))

(def-fn char-digit? (c)
  (and (char>=? c #\0) (char<=? c #\9)))

(def-fn char-alphanumeric? (c)
  (or (char-letter? c) (char-digit? c)))

(def-fn char-upper? (c)
  (and (char>=? c #\A) (char<=? c #\Z)))

(def-fn char-lower? (c)
  (and (char>=? c #\a) (char<=? c #\z)))

(def-fn char-punctuation? (c)
  (string-contains? ".,!?;:'\"-()[]{}/<>@#$%^&*+=|\\`~" (str c)))

;; ── Parsing helpers ──────────────────────────────────────────────
(def-fn string-parse-int (s)
  "Parse integer, returns nil on failure."
  (handle-error
    (lambda () (let ((n (string->number (string-trim s))))
                 (and n (integer? n) (floor n))))
    (lambda (_) nil)))

(def-fn string-parse-float (s)
  (handle-error
    (lambda () (string->number (string-trim s)))
    (lambda (_) nil)))

(def-fn string-parse-bool (s)
  (let ((t (string-lower (string-trim s))))
    (cond
      ((or (equal? t "true")  (equal? t "yes") (equal? t "1")) #t)
      ((or (equal? t "false") (equal? t "no")  (equal? t "0")) #f)
      (else nil))))

(def-fn string-extract-numbers (s)
  "Return list of all numbers found in s."
  (let loop ((chars (string->list s)) (acc (list)) (curr ""))
    (cond
      ((null? chars)
       (reverse (if (string-empty? curr) acc
                  (cons (string->number curr) acc))))
      ((or (char-digit? (car chars)) (char=? (car chars) #\.))
       (loop (cdr chars) acc (str curr (car chars))))
      (else
       (loop (cdr chars)
             (if (string-empty? curr) acc
               (cons (string->number curr) acc))
             "")))))

;; ── Levenshtein edit distance ────────────────────────────────────
(def-fn string-distance (a b)
  "Compute Levenshtein edit distance between two strings."
  (let* ((m    (string-length a))
         (n    (string-length b))
         (prev (vec->list (list->vec (range 0 (+ n 1))))))
    (let row-loop ((i 1) (prev prev))
      (if (> i m)
        (list-ref prev n)
        (let col-loop ((j 1) (cur (list 0)) (p prev))
          (if (> j n)
            (row-loop (+ i 1) (reverse cur))
            (let* ((cost (if (char=? (string-ref a (- i 1))
                                     (string-ref b (- j 1))) 0 1))
                   (val  (min (+ (list-ref p j) 1)
                              (+ (car cur) 1)
                              (+ (list-ref p (- j 1)) cost))))
              (col-loop (+ j 1) (cons val cur) p))))))))

(def-fn take (lst n)
  (if (or (null? lst) (= n 0)) (list)
    (cons (car lst) (take (cdr lst) (- n 1)))))

(def-fn drop (lst n)
  (if (or (null? lst) (= n 0)) lst (drop (cdr lst) (- n 1))))

(export
  ;; Predicates
  string-empty? string-blank? string-contains? string-starts? string-ends?
  ;; Slicing
  string-slice string-take string-drop string-last
  ;; Search
  string-index-of string-last-index-of
  ;; Case
  string-upper string-lower string-title-case
  string-camel->kebab string-kebab->camel
  ;; Trim / Pad
  string-trim string-trim-left string-trim-right
  string-pad-left string-pad-right make-string string-repeat
  ;; Replace / Split / Join
  string-replace string-replace-all
  string-split string-split-lines string-join
  ;; Pattern matching
  glob-match?
  ;; Formatting
  format format-float
  ;; Character categories
  char-letter? char-digit? char-alphanumeric?
  char-upper? char-lower? char-punctuation? char-whitespace?
  ;; Parsing
  string-parse-int string-parse-float string-parse-bool
  string-extract-numbers
  ;; Distance
  string-distance)
