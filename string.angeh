(def-module string)

(def split string.split)
(def join string.join)
(def replace string.replace)
(def trim string.trim)
(def lower string.lower)
(def upper string.upper)
(def starts-with? string.starts-with?)
(def ends-with? string.ends-with?)
(def contains? string.contains?)

(export
  split join replace trim
  lower upper starts-with?
  ends-with? contains?)
