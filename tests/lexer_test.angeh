;; lexer_test.angeh
;; Comprehensive Lexical scanning validation evaluating token integrity securely

(def-module lexer-test)
(import ../architectonic/lexer)

(def-fn run-lexer-tests ()
  (begin
    (print ">> [TEST] Executing Lexer Validation Suite...")
    (let ((source "(def x 100) hello")
          (tokens (tokenize source)))
      (begin
        ;; Validate generated counts and token fields inherently
        (print "  ↳ Lexed Tokens Generated: " (length tokens))
        (print "  ↳ Token 0 Type: " (get (get tokens 0) "type"))    ;; LPAREN
        (print "  ↳ Token 1 Value: " (get (get tokens 1) "value"))  ;; def
        (print "  ↳ SUCCESS: Token bounds isolated safely!")))))
