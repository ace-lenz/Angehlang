    "error_handling": {
      "exceptions": {
        "try_catch": {
          "python": "try:\n    # code\nexcept Exception as e:\n    # handle",
          "javascript": "try {\n    // code\n} catch (error) {\n    // handle\n}",
          "java": "try {\n    // code\n} catch (Exception e) {\n    // handle\n}",
          "cpp": "try {\n    // code\n} catch (const std::exception& e) {\n    // handle\n}",
          "csharp": "try {\n    // code\n} catch (Exception e) {\n    // handle\n}",
          "go": "defer func() {\n    if r := recover(); r != nil {\n        // handle\n    }\n}()",
          "rust": "match result {\n    Ok(value) => { /* success */ },\n    Err(error) => { /* handle */ }\n}",
          "swift": "do {\n    try riskyOperation()\n} catch {\n    // handle\n}",
          "php": "try {\n    // code\n} catch (Exception $e) {\n    // handle\n}",
          "ruby": "begin\n    # code\nrescue Exception => e\n    # handle\nend",
          "kotlin": "try {\n    // code\n} catch (e: Exception) {\n    // handle\n}"
        }
      }
    },
    "common_patterns": {
      "singleton": {
        "python": "class Singleton:\n    _instance = None\n    \n    @classmethod\n    def get_instance(cls):\n        if cls._instance is None:\n            cls._instance = cls()\n        return cls._instance",
        "javascript": "class Singleton {\n    static instance;\n    \n    static getInstance() {\n        if (!Singleton.instance) {\n            Singleton.instance = new Singleton();\n        }\n        return Singleton.instance;\n    }\n}",
        "java": "public class Singleton {\n    private static Singleton instance;\n    \n    private Singleton() {}\n    \n    public static Singleton getInstance() {\n        if (instance == null) {\n            instance = new Singleton();\n        }\n        return instance;\n    }\n}",
        "cpp": "class Singleton {\nprivate:\n    static Singleton* instance;\n    Singleton() {}\npublic:\n    static Singleton* getInstance() {\n        if (instance == nullptr) {\n            instance = new Singleton();\n        }\n        return instance;\n    }\n};",
        "csharp": "public class Singleton {\n    private static Singleton instance;\n    \n    private Singleton() {}\n    \n    public static Singleton Instance {\n        get {\n            if (instance == null) {\n                instance = new Singleton();\n            }\n            return instance;\n        }\n    }\n}"
      },
      "factory": {
        "python": "class Factory:\n    @staticmethod\n    def create_product(type):\n        if type == 'A':\n            return ProductA()\n        elif type == 'B':\n            return ProductB()",
        "javascript": "class Factory {\n    static createProduct(type) {\n        switch (type) {\n            case 'A': return new ProductA();\n            case 'B': return new ProductB();\n        }\n    }\n}",
        "java": "public class Factory {\n    public static Product createProduct(String type) {\n        switch (type) {\n            case \"A\": return new ProductA();\n            case \"B\": return new ProductB();\n            default: return null;\n        }\n    }\n}",
        "cpp": "class Factory {\npublic:\n    static Product* createProduct(std::string type) {\n        if (type == \"A\") return new ProductA();\n        if (type == \"B\") return new ProductB();\n        return nullptr;\n    }\n};",
        "csharp": "public class Factory {\n    public static Product CreateProduct(string type) {\n        switch (type) {\n            case \"A\": return new ProductA();\n            case \"B\": return new ProductB();\n            default: return null;\n        }\n    }\n}"
      }
    },
