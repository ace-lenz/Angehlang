        "switch_case": {
          "python": "match value:\n    case pattern:\n        # code\n    case _:\n        # default",
          "javascript": "switch (value) {\n    case pattern:\n        // code\n        break;\n    default:\n        // code\n}",
          "java": "switch (value) {\n    case pattern:\n        // code\n        break;\n    default:\n        // code\n}",
          "cpp": "switch (value) {\n    case pattern:\n        // code\n        break;\n    default:\n        // code\n}",
          "csharp": "switch (value) {\n    case pattern:\n        // code\n        break;\n    default:\n        // code\n}",
          "go": "switch value {\n    case pattern:\n        // code\n    default:\n        // code\n}",
          "rust": "match value {\n    pattern => { /* code */ },\n    _ => { /* default */ }\n}",
          "swift": "switch value {\n    case pattern:\n        // code\n    default:\n        // code\n}",
          "php": "switch ($value) {\n    case pattern:\n        // code\n        break;\n    default:\n        // code\n}",
