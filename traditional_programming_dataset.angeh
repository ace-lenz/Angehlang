{
  "traditional_programming_dataset": {
    "version": "1.0",
    "description": "Complete dataset for traditional programming languages with detailed specifications, comparisons, and implementations",
    "overview": {
      "paradigms": {
        "procedural": "Step-by-step instruction execution",
        "object_oriented": "Data and behavior encapsulation",
        "functional": "Mathematical function composition",
        "scripting": "Runtime interpretation and automation",
        "declarative": "What to do, not how to do it",
        "logic": "Rule-based problem solving",
        "concurrent": "Parallel execution and synchronization"
      },
      "execution_models": {
        "compiled": "Source code → machine code (C++, Java)",
        "interpreted": "Source code → runtime execution (Python, JavaScript)",
        "hybrid": "Compilation + interpretation (Java, C#)",
        "just_in_time": "Runtime compilation (Java JVM, .NET CLR)",
        "ahead_of_time": "Pre-execution compilation (Go, Rust)"
      }
    },
    "languages": {
      "python": {
        "paradigm": ["object_oriented", "procedural", "functional"],
        "execution": "interpreted",
        "typing": "dynamic",
        "year_created": 1991,
        "creator": "Guido van Rossum",
        "use_cases": ["web development", "data science", "automation", "AI/ML"],
        "strengths": ["readability", "extensive libraries", "rapid development"],
        "weaknesses": ["performance", "mobile development"],
        "syntax": {
          "hello_world": "print('Hello, World!')",
          "variables": "name = 'Alice'\nage = 30",
          "functions": "def greet(name):\n    return f'Hello, {name}!'",
          "classes": "class Person:\n    def __init__(self, name):\n        self.name = name",
          "loops": "for i in range(5):\n    print(i)",
          "conditionals": "if age > 18:\n    print('Adult')\nelse:\n    print('Minor')"
        }
      },
      "javascript": {
        "paradigm": ["object_oriented", "functional", "procedural"],
        "execution": "interpreted",
        "typing": "dynamic",
        "year_created": 1995,
        "creator": "Brendan Eich",
        "use_cases": ["web development", "server-side", "mobile apps", "desktop apps"],
        "strengths": ["ubiquitous", "flexible", "large ecosystem"],
        "weaknesses": ["type safety", "performance"],
        "syntax": {
          "hello_world": "console.log('Hello, World!');",
          "variables": "let name = 'Alice';\nconst age = 30;",
          "functions": "function greet(name) {\n    return `Hello, ${name}!`;\n}",
          "arrow_functions": "const greet = (name) => `Hello, ${name}!`;",
          "classes": "class Person {\n    constructor(name) {\n        this.name = name;\n    }\n}",
          "loops": "for (let i = 0; i < 5; i++) {\n    console.log(i);\n}",
          "conditionals": "if (age > 18) {\n    console.log('Adult');\n} else {\n    console.log('Minor');\n}"
        }
      },
      "java": {
        "paradigm": ["object_oriented"],
        "execution": "hybrid",
        "typing": "static",
        "year_created": 1995,
        "creator": "James Gosling",
        "use_cases": ["enterprise applications", "Android apps", "web servers", "big data"],
        "strengths": ["platform independence", "performance", "security"],
        "weaknesses": ["verbosity", "memory usage"],
        "syntax": {
          "hello_world": "public class Hello {\n    public static void main(String[] args) {\n        System.out.println(\"Hello, World!\");\n    }\n}",
          "variables": "String name = \"Alice\";\nint age = 30;",
          "methods": "public String greet(String name) {\n    return \"Hello, \" + name + \"!\";\n}",
          "classes": "public class Person {\n    private String name;\n    \n    public Person(String name) {\n        this.name = name;\n    }\n}",
          "loops": "for (int i = 0; i < 5; i++) {\n    System.out.println(i);\n}",
          "conditionals": "if (age > 18) {\n    System.out.println(\"Adult\");\n} else {\n    System.out.println(\"Minor\");\n}"
        }
      },
      "cpp": {
        "paradigm": ["object_oriented", "procedural"],
        "execution": "compiled",
        "typing": "static",
        "year_created": 1985,
        "creator": "Bjarne Stroustrup",
        "use_cases": ["system programming", "game development", "high-performance computing", "embedded systems"],
        "strengths": ["performance", "control", "portability"],
        "weaknesses": ["complexity", "memory management"],
        "syntax": {
          "hello_world": "#include <iostream>\n\nint main() {\n    std::cout << \"Hello, World!\" << std::endl;\n    return 0;\n}",
          "variables": "std::string name = \"Alice\";\nint age = 30;",
          "functions": "std::string greet(std::string name) {\n    return \"Hello, \" + name + \"!\";\n}",
          "classes": "class Person {\nprivate:\n    std::string name;\npublic:\n    Person(std::string n) : name(n) {}\n};",
          "loops": "for (int i = 0; i < 5; i++) {\n    std::cout << i << std::endl;\n}",
          "conditionals": "if (age > 18) {\n    std::cout << \"Adult\" << std::endl;\n} else {\n    std::cout << \"Minor\" << std::endl;\n}"
        }
      },
      "csharp": {
        "paradigm": ["object_oriented"],
        "execution": "hybrid",
        "typing": "static",
        "year_created": 2000,
        "creator": "Microsoft",
        "use_cases": ["Windows applications", "web development", "game development", "enterprise software"],
        "strengths": ["modern syntax", ".NET ecosystem", "cross-platform"],
        "weaknesses": ["Windows-centric history", "learning curve"],
        "syntax": {
          "hello_world": "using System;\n\nclass Program {\n    static void Main() {\n        Console.WriteLine(\"Hello, World!\");\n    }\n}",
          "variables": "string name = \"Alice\";\nint age = 30;",
          "methods": "public string Greet(string name) {\n    return $\"Hello, {name}!\";\n}",
          "classes": "public class Person {\n    public string Name { get; set; }\n    \n    public Person(string name) {\n        Name = name;\n    }\n}",
          "loops": "for (int i = 0; i < 5; i++) {\n    Console.WriteLine(i);\n}",
          "conditionals": "if (age > 18) {\n    Console.WriteLine(\"Adult\");\n} else {\n    Console.WriteLine(\"Minor\");\n}"
        }
      },
      "go": {
        "paradigm": ["procedural", "concurrent"],
        "execution": "compiled",
        "typing": "static",
        "year_created": 2009,
        "creator": "Google",
        "use_cases": ["cloud services", "networking", "distributed systems", "CLI tools"],
        "strengths": ["concurrency", "performance", "simplicity"],
        "weaknesses": ["generics (until recently)", "error handling verbosity"],
        "syntax": {
          "hello_world": "package main\n\nimport \"fmt\"\n\nfunc main() {\n    fmt.Println(\"Hello, World!\")\n}",
          "variables": "name := \"Alice\"\nage := 30",
          "functions": "func greet(name string) string {\n    return \"Hello, \" + name + \"!\"\n}",
          "structs": "type Person struct {\n    Name string\n}",
          "loops": "for i := 0; i < 5; i++ {\n    fmt.Println(i)\n}",
          "conditionals": "if age > 18 {\n    fmt.Println(\"Adult\")\n} else {\n    fmt.Println(\"Minor\")\n}"
        }
      },
      "rust": {
        "paradigm": ["functional", "procedural"],
        "execution": "compiled",
        "typing": "static",
        "year_created": 2010,
        "creator": "Mozilla",
        "use_cases": ["system programming", "web assembly", "embedded systems", "performance-critical applications"],
        "strengths": ["memory safety", "performance", "concurrency"],
        "weaknesses": ["learning curve", "compilation time"],
        "syntax": {
          "hello_world": "fn main() {\n    println!(\"Hello, World!\");\n}",
          "variables": "let name = \"Alice\";\nlet age = 30;",
          "functions": "fn greet(name: &str) -> String {\n    format!(\"Hello, {}!\", name)\n}",
          "structs": "struct Person {\n    name: String,\n}",
          "loops": "for i in 0..5 {\n    println!(\"{}\", i);\n}",
          "conditionals": "if age > 18 {\n    println!(\"Adult\");\n} else {\n    println!(\"Minor\");\n}"
        }
      },
      "swift": {
        "paradigm": ["object_oriented", "functional"],
        "execution": "hybrid",
        "typing": "static",
        "year_created": 2014,
        "creator": "Apple",
        "use_cases": ["iOS/macOS apps", "server-side", "system programming"],
        "strengths": ["safety", "performance", "modern syntax"],
        "weaknesses": ["Apple ecosystem focus", "young language"],
        "syntax": {
          "hello_world": "print(\"Hello, World!\")",
          "variables": "let name = \"Alice\"\nvar age = 30",
          "functions": "func greet(name: String) -> String {\n    return \"Hello, \\(name)!\"\n}",
          "classes": "class Person {\n    var name: String\n    \n    init(name: String) {\n        self.name = name\n    }\n}",
          "loops": "for i in 0..<5 {\n    print(i)\n}",
          "conditionals": "if age > 18 {\n    print(\"Adult\")\n} else {\n    print(\"Minor\")\n}"
        }
      },
      "php": {
        "paradigm": ["object_oriented", "procedural"],
        "execution": "interpreted",
        "typing": "dynamic",
        "year_created": 1995,
        "creator": "Rasmus Lerdorf",
        "use_cases": ["web development", "server-side scripting", "content management"],
        "strengths": ["web integration", "rapid development", "ubiquitous hosting"],
        "weaknesses": ["inconsistent API", "security concerns"],
        "syntax": {
          "hello_world": "<?php\necho \"Hello, World!\";\n?>",
          "variables": "$name = \"Alice\";\n$age = 30;",
          "functions": "function greet($name) {\n    return \"Hello, \" . $name . \"!\";\n}",
          "classes": "class Person {\n    private $name;\n    \n    public function __construct($name) {\n        $this->name = $name;\n    }\n}",
          "loops": "for ($i = 0; $i < 5; $i++) {\n    echo $i;\n}",
          "conditionals": "if ($age > 18) {\n    echo \"Adult\";\n} else {\n    echo \"Minor\";\n}"
        }
      },
      "ruby": {
        "paradigm": ["object_oriented", "functional"],
        "execution": "interpreted",
        "typing": "dynamic",
        "year_created": 1995,
        "creator": "Yukihiro Matsumoto",
        "use_cases": ["web development", "automation", "prototyping", "DSL creation"],
        "strengths": ["expressiveness", "developer happiness", "metaprogramming"],
        "weaknesses": ["performance", "concurrency"],
        "syntax": {
          "hello_world": "puts \"Hello, World!\"",
          "variables": "name = \"Alice\"\nage = 30",
          "methods": "def greet(name)\n    \"Hello, #{name}!\"\nend",
          "classes": "class Person\n    attr_accessor :name\n    \n    def initialize(name)\n        @name = name\n    end\nend",
          "loops": "5.times do |i|\n    puts i\nend",
          "conditionals": "if age > 18\n    puts \"Adult\"\nelse\n    puts \"Minor\"\nend"
        }
      },
      "kotlin": {
        "paradigm": ["object_oriented", "functional"],
        "execution": "hybrid",
