          "swift": "if condition {\n    // code\n} else if condition {\n    // code\n} else {\n    // code\n}",
          "php": "if ($condition) {\n    // code\n} elseif ($condition) {\n    // code\n} else {\n    // code\n}",
          "ruby": "if condition\n    # code\nelsif condition\n    # code\nelse\n    # code\nend",
