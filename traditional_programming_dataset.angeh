        "java": "public ReturnType methodName(Parameters) {\n    // code\n    return value;\n}",
        "cpp": "ReturnType functionName(Parameters) {\n    // code\n    return value;\n}",
        "csharp": "public ReturnType MethodName(Parameters) {\n    // code\n    return value;\n}",
        "go": "func functionName(parameters) returnType {\n    // code\n    return value\n}",
        "rust": "fn function_name(parameters) -> ReturnType {\n    // code\n    value\n}",
