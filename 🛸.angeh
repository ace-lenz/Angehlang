(def-module universal-launcher
  "🛸 Angeh Universal Launcher: Multi-Payload Execution & Context Reification")

(import 🏃‍♂️)
(import 🏗️)
(import 🌐)
(import 📦)
(import universe-os-kernel)
(import language-bridge-advanced)

;; ============================================================
;; LAUNCHER TYPES
;; ============================================================

(def-type LaunchPayload
  (struct (
    (type symbol)                ; 'ZIP | 'APK | 'WEB | 'IDE | 'LLM | 'OS
    (source string)              ; File path or URI
    (target-context symbol)      ; 'NATIVE | 'VIRTUAL | 'HYBRID
    (sandboxed bool)
    (optimized bool)
    (supplied-deps (new-qlist))
  )))

(def-const PAYLOAD_REGISTRY (new-qhash-map))

;; ============================================================
;; CORE OPERATIONS
;; ============================================================

(def-fn identify-payload (source-path)
  "Heuristically determines the payload type based on signature"
  (print (str "🔍 🛸 [IDENTIFY] Analyzing payload: " source-path))
  (cond
    ((str-ends-with? source-path ".zip") 'ZIP)
    ((str-ends-with? source-path ".apk") 'APK)
    ((str-ends-with? source-path ".angeh") 'APP)
    ((str-starts-with? source-path "http") 'WEB)
    (else 'GENERIC_SOFTWARE)))

(def-fn prepare-context! (payload-type)
  "Wires the substrate for specific execution requirements"
  (print (str "⚙️ 🛸 [PREPARE] Configuration context for: " payload-type))
  
  ;; Boot the Organ System
  (print "⚙️ 🛸 [BIODIGITAL] Waking up Synthetic Organs...")
  (import 🧠)
  (import 🫀)
  (import 🫁)
  (🧠.synchronize-swarm!)
  (🫀.generate-pulse!)
  
  (match payload-type
    ('WEB (🌐.inject-web-layer!))
    ('OS (universe-os-kernel.init-kernel!))
    ('IDE (studios.boot-ide-core!))
    ('LLM (angeh-llm-core.warmup!))
    ('APK (android-bridge.prepare-vm!))
    (_ (print "⚡ Normal Photonic Context ready."))))

(def-fn auto-supply-dependencies! (payload)
  "Scans the package for missing links and automatically fetches/connects them"
  (print (str "🧬 🛸 [SUPPLY] Scanning dependencies for " (payload.source payload) "..."))
  (let ((missing (📑.identify-missing-strands (payload.source payload))))
    (if (empty? missing)
      (print "✅ All dependencies supplied.")
      (do
        (print (str "🏗️ 🛸 [FETCH] Missing: " missing))
        (for-each dep missing
          (do
            (let ((strand (remote-payload-pull! (str "https://dots.angeh.io/" dep))))
              (qlist-append! (payload.supplied-deps payload) strand))))
        (print "✅ Environment fully supplied.")))))

(def-fn optimize-payload! (payload)
  "Refactors and compresses the payload to fit the local hardware profile"
  (print (str "⚡ 🛸 [OPTIMIZE] Fitting " (payload.source payload) " for local substrate..."))
  (let ((profile (hardware-optimizer.get-profile)))
    (🏗️.optimize-jit-paths! (struct ((project-name (payload.source payload)) (optimization-level 100))))
    (set! (payload.optimized payload) true)
    (print "✅ Payload optimized for maximum resonance.")))

(def-fn register-launcher! (type handler-fn)
  "Dynamically adds support for a new application/payload type"
  (print (str "🛸 📥 [REGISTER] Adding handler for type: " type))
  (qhash-set! PAYLOAD_REGISTRY type handler-fn))

(def-fn launch! (payload)
  "Executes the payload with auto-optimization and dependency supply"
  (print (str "🚀 🛸 [LAUNCH] Initiating " (payload.type payload) " from source " (payload.source payload)))
  
  ;; Intelligence Phase
  (auto-supply-dependencies! payload)
  (optimize-payload! payload)
  
  (let ((type (payload.type payload)))
    (prepare-context! type)
    
    (match type
      ('ZIP 
        (do
          (print "📦 🛸 [UNPACK] Extracting zip to memory...")
          (let ((extracted (unzip-to-substrate (payload.source payload))))
            (🏃‍♂️.sprint! extracted))))
      ('APK
        (do
          (print "🤖 🛸 [ANDROID] Reifying APK into Quantum Strands...")
          (let ((reified (🏗️.reify-to-native! (payload.source payload) 'TOTAL_NATIVE)))
            (🏃‍♂️.marathon! reified 9999))))
      ('WEB
        (do
          (print "🌐 🛸 [WEB] Hot-swapping View Layer...")
          (📑.shift-page-context! (payload.source payload))))
      ('OS
        (do
          (print "🌌 🛸 [OS] Booting Virtual Operating System...")
          (universe-os-kernel.boot-os! (payload.source payload))))
      ('APP
        (🏃‍♂️.sprint! (load-module (payload.source payload))))
      (_
        (match (qhash-get PAYLOAD_REGISTRY type)
          ((Some handler) (handler payload))
          (Nothing 
            (do
              (print "🔨 🛸 [GENERIC] Executing via Universal Bridge...")
              (bridge-execute! (payload.source payload))))))))
  
  (print "✅ Launch sequence active. Resonance stable."))

;; ============================================================
;; LAUNCHER UTILITIES
;; ============================================================

(def-fn package-bundle-creator! (source-dir bundle-name)
  "Packages a directory into a secure, launcher-ready ZIP bundle"
  (print (str "📦 🛸 [BUNDLE] Creating universal package: " bundle-name))
  (let ((zip-path (str source-dir ".zip")))
    (compress-directory! source-dir zip-path)
    (print (str "✅ Bundle created at: " zip-path))
    zip-path))

(def-fn remote-payload-pull! (uri)
  "Downloads and prepares a payload from the global photonic cloud"
  (print (str "☁️ 🛸 [PULL] Fetching remote payload: " uri))
  (let ((local-tmp (fetch-remote-resource! uri)))
    (quick-launch! local-tmp)))

(def-fn quick-launch! (path)
  "One-click entry point with automatic intelligence/optimization"
  (let ((type (identify-payload path)))
    (launch! (LaunchPayload type path 'HYBRID true false (new-qlist)))))

(export
  launch!
  quick-launch!
  register-launcher!
  optimize-payload!
  auto-supply-dependencies!
  package-bundle-creator!
  remote-payload-pull!
  identify-payload)
